{
	"appId": "com.pocketgrocery.app",
	"appName": "PocketGrocery",
	"server": {
		"url": "https://pocketgrocery.com",
		"cleartext": false,
		"androidScheme": "https"
	},
	"ios": {
		"contentInset": "automatic"
	},
	"android": {
		"allowMixedContent": true,
		"backgroundColor": "#ffffff"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"backgroundColor": "#ffffff",
			"showSpinner": false
		},
		"GoogleAuth": {
			"scopes": [
				"profile",
				"email"
			],
          "androidClientId": "75115921613-6cju6n4kiv2utkhof37ruqquu7ru7m13.apps.googleusercontent.com",
          "iosClientId": "75115921613-ja3eu44bnuvukthof37ruqquu7ru7m13.apps.googleusercontent.com",
			"forceCodeForRefreshToken": true
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		}
	},
	"packageClassList": [
		"AppPlugin",
		"KeyboardPlugin",
		"PushNotificationsPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
